coverage
*.lcov

# nyc test coverage
.nyc_output

# Grunt intermediate storage (https://gruntjs.com/creating-plugins#storing-task-files)
.grunt

# Bower dependency directory (https://bower.io/)
bower_components

# node-waf configuration
.lock-wscript

# Compiled binary addons (https://nodejs.org/api/addons.html)
build/Release

# Dependency directories
node_modules/
jspm_packages/

# Snowpack dependency directory; first-party local bundles (https://snowpack.dev/)
web_modules/

# TypeScript cache
*.tsbuildinfo

# Optional npm cache directory
.npm

# Optional eslint cache
.eslintcache

# Optional stylelint cache
.stylelintcache

# Microbundle cache
.rts2_cache_cmd
.rts2_cache_src
.rts2_cache_ts

# gatsby files
.cache/
# Comment in case gatsby is contentful
# public

# vuepress build output
.vuepress/dist

# Serverless Webpack templates/files
.webpack/

# Yii2 backup directory
# backend/web/assets/
# frontend/web/assets/

# vlc/mplayer state files
.vlc

